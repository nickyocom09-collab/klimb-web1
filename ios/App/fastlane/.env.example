# Copy this file to `.env` (same folder) and fill in your real values.
# `.env` is gitignored — never commit your key.
#
# Create the key at: App Store Connect → Users and Access → Integrations →
# App Store Connect API → generate a key with "App Manager" access.
# Download the .p8 file ONCE (Apple only lets you download it a single time).

# The 10-character Key ID shown next to the key.
ASC_KEY_ID=XXXXXXXXXX

# The Issuer ID shown at the top of the API keys page (a UUID).
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Path to the downloaded .p8 file. Put the file in this fastlane/ folder
# (it's gitignored) and point to it here.
ASC_KEY_FILEPATH=./fastlane/AuthKey_XXXXXXXXXX.p8
